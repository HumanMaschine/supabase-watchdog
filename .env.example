# Supabase Watchdog — Environment Variables
# Copy this file to .env and fill in your values.
# For Deno Deploy, set these in the project dashboard instead.

# ── Required ─────────────────────────────────────────────

# Supabase personal access token
# Generate at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_your_token_here

# Telegram bot token
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram chat or group ID where alerts will be sent
# Tip: send a message to your bot, then visit:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# Look for "chat":{"id": ...} in the response
TELEGRAM_CHAT_ID=-1001234567890

# Projects to monitor (env-var config path, not needed if using YAML)
# Format: ref:name,ref:name
# Find your project ref in the Supabase dashboard URL: https://supabase.com/dashboard/project/<ref>
WATCHDOG_PROJECTS=your_project_ref:my-app

# ── Optional ─────────────────────────────────────────────

# Telegram transport mode: "webhook" (for Deno Deploy) or "polling" (for Docker/local)
# WATCHDOG_TELEGRAM_MODE=polling

# Public base URL for webhook mode (required when WATCHDOG_TELEGRAM_MODE=webhook)
# WATCHDOG_BASE_URL=https://your-app.deno.dev

# Token to protect the dashboard (if unset, dashboard is public)
# WATCHDOG_DASHBOARD_TOKEN=your_secret_token

# Polling interval (default: 5m)
# WATCHDOG_INTERVAL=5m

# Comma-separated log sources (default: all 7)
# WATCHDOG_SOURCES=edge_logs,auth_logs,postgres_logs,storage_logs,realtime_logs,postgrest_logs,supavisor_logs

# Minimum HTTP status code to alert on (default: 500)
# WATCHDOG_MIN_STATUS=500

# Comma-separated patterns to ignore (default: none)
# WATCHDOG_IGNORE_PATTERNS=healthcheck,favicon.ico

# Max alerts per polling interval (default: 20)
# WATCHDOG_MAX_ALERTS=20
